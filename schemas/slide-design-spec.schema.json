{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pptx-creator.local/slide-design-spec.schema.json",
  "title": "Slide Design Specs",
  "type": "object",
  "required": ["slides"],
  "properties": {
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "layoutType", "intent", "mainIdea", "visualPlan", "contentSlots", "editableTarget"],
        "properties": {
          "id": { "type": "string", "pattern": "^slide-" },
          "layoutType": { "type": "string" },
          "intent": { "type": "string" },
          "mainIdea": { "type": "string" },
          "visualPlan": {
            "type": "object",
            "required": ["focalPoint", "density", "visualWeight"],
            "properties": {
              "focalPoint": { "type": "string" },
              "density": { "type": "string", "enum": ["low", "medium", "high"] },
              "visualWeight": { "type": "object" }
            }
          },
          "contentSlots": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slot", "role"],
              "properties": {
                "slot": { "type": "string" },
                "role": { "type": "string" },
                "content": {}
              }
            }
          },
          "editableTarget": { "type": "number", "minimum": 1, "maximum": 5 }
        }
      }
    }
  }
}
