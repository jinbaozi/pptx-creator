{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pptx-creator.local/consistency-report-batch.schema.json",
  "title": "Batch Consistency Report Aggregate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "createdAt",
    "batch",
    "editabilityDistribution",
    "averageCoordinateDriftPx",
    "fontFallbackRate",
    "paletteMatch",
    "perDeckReports",
    "layoutSafetyDistribution",
    "averageSlopRisk"
  ],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalDecks", "passedDecks", "failedDecks"],
      "properties": {
        "totalDecks": { "type": "integer", "minimum": 0 },
        "passedDecks": { "type": "integer", "minimum": 0 },
        "failedDecks": { "type": "integer", "minimum": 0 }
      }
    },
    "editabilityDistribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["1", "2", "3", "4", "5"],
      "properties": {
        "1": { "type": "integer", "minimum": 0 },
        "2": { "type": "integer", "minimum": 0 },
        "3": { "type": "integer", "minimum": 0 },
        "4": { "type": "integer", "minimum": 0 },
        "5": { "type": "integer", "minimum": 0 }
      }
    },
    "averageCoordinateDriftPx": { "type": "number", "minimum": 0 },
    "fontFallbackRate": { "type": "number", "minimum": 0, "maximum": 1 },
    "paletteMatch": { "type": "number", "minimum": 0, "maximum": 1 },
    "perDeckReports": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "layoutSafetyDistribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "violated-with-flag", "violated-blocked", "unknown"],
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "violated-with-flag": { "type": "integer", "minimum": 0 },
        "violated-blocked": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 }
      }
    },
    "averageSlopRisk": { "type": "number", "minimum": 0, "maximum": 100 }
  },
  "not": {
    "anyOf": [
      {
        "required": ["inputType"]
      },
      {
        "required": ["inputSource"]
      },
      {
        "required": ["floorViolation"]
      },
      {
        "required": ["editabilityFloor"]
      }
    ]
  }
}
