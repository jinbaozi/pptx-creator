{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pptx-creator.local/storyboard.schema.json",
  "title": "Deck Storyboard",
  "type": "object",
  "required": ["title", "audience", "goal", "language", "slides"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "message", "contentBlocks"],
        "properties": {
          "id": { "type": "string", "pattern": "^slide-" },
          "role": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "contentBlocks": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
