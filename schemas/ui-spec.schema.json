{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pptx-creator.local/ui-spec.schema.json",
  "title": "UI Spec",
  "type": "object",
  "required": ["version", "slides"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "layoutPattern", "regions"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "layoutPattern": { "type": "string", "minLength": 1 },
          "regions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "role"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "minLength": 1 },
                "priority": { "type": "number" }
              }
            }
          }
        }
      }
    }
  }
}
