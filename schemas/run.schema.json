{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pptx-creator.local/run.schema.json",
  "title": "Generation Run Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["runId", "mode", "status", "input", "artifacts", "directions"],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["creative", "replica", "hybrid"] },
    "status": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "required": ["type", "summary"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "storyboard": { "type": "string" },
        "designDirection": { "type": "string" },
        "slideDesignSpecs": { "type": "string" },
        "manifest": { "type": "string" },
        "pptx": { "type": "string" },
        "previews": { "type": "array", "items": { "type": "string" } },
        "reviews": { "type": "array", "items": { "type": "string" } },
        "sources": { "type": "string" },
        "assetRegistry": { "type": "string" }
      }
    },
    "directions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "status", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "score": { "type": "number" },
          "path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metadata": { "type": "object" }
  }
}
