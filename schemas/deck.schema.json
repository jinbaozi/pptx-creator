{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pptx-creator.local/deck.schema.json",
  "title": "Deck Manifest",
  "type": "object",
  "required": ["version", "designSystem", "deck", "assets", "slides"],
  "properties": {
    "version": { "type": "string", "const": "0.1.1" },
    "designSystem": {
      "type": "object",
      "required": ["source", "name", "mode"],
      "properties": {
        "source": { "type": "string" },
        "name": { "type": "string" },
        "mode": { "type": "string", "enum": ["strict", "balanced", "creative", "inspired"] }
      }
    },
    "deck": {
      "type": "object",
      "required": ["title", "language", "size"],
      "properties": {
        "title": { "type": "string" },
        "language": { "type": "string" },
        "size": {
          "type": "object",
          "required": ["preset", "width", "height", "unit"],
          "properties": {
            "preset": { "type": "string" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "unit": { "type": "string", "const": "in" }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "src"],
        "properties": {
          "id": { "type": "string" },
          "src": { "type": "string" }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "background", "elements"],
        "properties": {
          "id": { "type": "string", "pattern": "^slide-" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "notes": { "type": "string" },
          "background": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["solid", "image"] },
              "color": { "type": "string" },
              "src": { "type": "string" }
            }
          },
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "id", "x", "y", "w", "h"],
              "properties": {
                "type": { "type": "string", "enum": ["text", "shape", "image", "table", "line", "chart", "icon", "diagram", "cropped-asset"] },
                "id": { "type": "string" },
                "x": { "type": "number" },
                "y": { "type": "number" },
                "w": { "type": "number", "exclusiveMinimum": 0 },
                "h": { "type": "number", "exclusiveMinimum": 0 },
                "text": { "type": "string" },
                "shape": { "type": "string", "enum": ["rect", "roundRect", "ellipse"] },
                "src": { "type": "string" },
                "headers": { "type": "array", "items": { "type": "string" } },
                "rows": { "type": "array" },
                "kind": {
                  "type": "string",
                  "enum": [
                    "bar",
                    "line",
                    "pie",
                    "stackedBar",
                    "horizontalBar",
                    "groupedBar",
                    "kpiGroup",
                    "sparkline",
                    "layeredArchitecture",
                    "compilerPipeline",
                    "capabilityStack",
                    "swimlane",
                    "matrixMap"
                  ]
                },
                "name": { "type": "string", "enum": ["check", "x", "info", "arrow-right"] },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["label"],
                    "properties": {
                      "label": { "type": "string" },
                      "value": { "type": "number" },
                      "series": {
                        "type": "object",
                        "minProperties": 1,
                        "additionalProperties": { "type": "number" }
                      },
                      "color": { "type": "string" }
                    },
                    "anyOf": [
                      { "required": ["value"] },
                      { "required": ["series"] }
                    ]
                  }
                },
                "style": { "type": "object" },
                "layers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["label", "nodes"],
                    "properties": {
                      "label": { "type": "string" },
                      "nodes": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                },
                "lanes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["label", "nodes"],
                    "properties": {
                      "label": { "type": "string" },
                      "nodes": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                },
                "columns": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
